#!/bin/sh
#
# Pre-push hook: prevent direct pushes to main/master.
# Developers must use feature branches and open PRs instead.

PROTECTED_BRANCHES="^(main|master)$"

while read local_ref local_sha remote_ref remote_sha; do
  remote_branch=$(echo "$remote_ref" | sed 's|refs/heads/||')

  if echo "$remote_branch" | grep -qE "$PROTECTED_BRANCHES"; then
    echo ""
    echo "  PUSH REJECTED"
    echo ""
    echo "  Direct pushes to '$remote_branch' are not allowed."
    echo "  Please use a feature branch and open a pull request."
    echo ""
    echo "  To fix this:"
    echo "    git checkout -b my-feature-branch"
    echo "    git push origin my-feature-branch"
    echo "    # Then open a PR on GitHub"
    echo ""
    exit 1
  fi
done

exit 0
