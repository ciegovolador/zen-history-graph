{
  "manifest_version": 2,
  "name": "ZEN History Graph",
  "version": "2.1.0",
  "description": "Convert browser history into a knowledge graph ready for RAG — with interactive visualizer",
  "permissions": [
    "history",
    "storage",
    "tabs"
  ],
  "background": {
    "scripts": ["background/background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_title": "ZEN History Graph"
  },
  "web_accessible_resources": [
    "visualizer/visualizer.html",
    "visualizer/visualizer.js",
    "visualizer/visualizer.css"
  ],
  "icons": {}
}
